    {f regular : ℂ → ℂ} {x : ℂ} {n : ℕ} {M : ℝ}
    (hsep : ∀ᶠ z in 𝓝[≠] x,
      logDeriv f z - (n : ℂ) * (z - x)⁻¹ = regular z)
