    {ρ : ℂ} (h : _root_.RiemannHypothesis.IsNontrivialZero ρ) :
    _root_.RiemannHypothesis.IsNontrivialZero (1 - ρ) :=
  PrimeNumberTheorem.nontrivial_zero_symmetric' h

