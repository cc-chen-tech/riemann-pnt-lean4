      hm ha ha_nonneg ?_ hpoly
  intro k hk
  have hupper :=
    re_neg_deriv_div_riemannZeta_finset_right_shift_le_log_norm_of_affine_logDeriv_re_le_half_radius
      (Are := Are) (Bre := Bre) (Acenter := Acenter) (Bcenter := Bcenter)
      (r := r) (H := H) (σ := σ) (S := S.erase m)
      (τ := fun k => (k : ℝ) * t)
