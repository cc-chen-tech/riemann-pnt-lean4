    (S : Finset ℂ) (F : ℂ → ℂ) (pair : ℂ → ℂ)
    (hpair : ∀ ρ ∈ S, 0 ≤ (F ρ).re + (F (pair ρ)).re) :
    0 ≤ ∑ ρ ∈ S, ((F ρ).re + (F (pair ρ)).re) :=
  PrimeNumberTheorem.finite_zero_sum_nonnegative_of_pairing_condition
    S F pair hpair

