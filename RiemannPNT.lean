/-- Public monotonicity principle for zero-free strips under width shrinkage. -/
theorem zero_free_region_mono_width
    {T0 : ℝ} {width_small width_large : ℝ → ℝ}
    (hlarge : ∀ s : ℂ, T0 ≤ |s.im| →
