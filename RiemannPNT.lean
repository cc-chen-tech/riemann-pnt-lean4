theorem logDerivVerticalLogBound_mono_const
    {C D T0 : ℝ} (h : LogDerivVerticalLogBound C T0)
    (hCD : C ≤ D) :
    LogDerivVerticalLogBound D T0 :=
  ZeroFreeRegion.logDerivVerticalLogBound_mono_const h hCD

