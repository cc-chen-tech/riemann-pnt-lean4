    {ρ : ℂ}
    (hRH : _root_.RiemannHypothesis.Statement)
    (h : _root_.RiemannHypothesis.IsNontrivialZero ρ) :
    ρ.re = 1 / 2 ∧ (1 - ρ).re = 1 / 2 :=
  PrimeNumberTheorem.rh_zero_symmetric_self_consistent hRH h

