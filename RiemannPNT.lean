    {f : ℂ → ℂ} {M R : ℝ} {z : ℂ}
    (hM : 0 < M) (hf : DifferentiableOn ℂ f (Metric.ball 0 R))
    (hf₁ : Set.MapsTo f (Metric.ball 0 R) {w | w.re ≤ M})
