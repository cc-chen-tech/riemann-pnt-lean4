    (-deriv riemannZeta s / riemannZeta s).re =
      ∑' n : ℕ,
        Λ n * Real.cos (s.im * Real.log n) / (n : ℝ) ^ s.re :=
  ZeroFreeRegion.log_deriv_zeta_re_series s hs

