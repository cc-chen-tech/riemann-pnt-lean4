abbrev btyRawCoeff : ℕ → ℤ := ZeroFreeRegion.btyRawCoeff

/-- Public complex-valued BTY coefficient table. -/
abbrev btyExpCoeff : ℕ → ℂ := ZeroFreeRegion.btyExpCoeff

