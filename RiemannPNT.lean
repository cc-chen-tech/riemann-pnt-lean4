    (hK : 0 ≤ K) (hd : 0 < d) :
    ∃ a c : ℝ, 0 < a ∧ 0 < c ∧
      a ≤ Real.log 2 ∧ a ≤ d * Real.log 2 ∧
      3 * C / a + K < 4 / (a + c) :=
  ZeroFreeRegion.exists_sigmaOf_log_margin_constants hC_pos hC_lt hK hd

