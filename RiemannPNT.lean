    Tendsto (fun s : ℂ => (s - 1) ^ 2 * riemannZeta s) (𝓝[≠] 1) (𝓝 0) :=
  PrimeNumberTheorem.riemannZeta_pole_simple

/-- Public RH symmetry consistency for nontrivial zeros. -/
