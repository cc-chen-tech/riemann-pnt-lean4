            (n : ℝ) ^ σ)
    (hpoly : ∀ θ : ℝ, 0 ≤ ∑ k ∈ S, a k * Real.cos ((k : ℝ) * θ)) :
    0 ≤
      ∑ k ∈ S, a k *
        (-deriv riemannZeta ((σ : ℂ) + (k : ℂ) * Complex.I * t) /
          riemannZeta ((σ : ℂ) + (k : ℂ) * Complex.I * t)).re :=
  ZeroFreeRegion.log_deriv_zeta_nonneg_finset_combination
    σ hσ t S a hseries hpoly

