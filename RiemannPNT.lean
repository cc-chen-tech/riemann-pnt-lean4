    ∃ a c : ℝ, 0 < a ∧ 0 < c ∧
      a ≤ Real.log 2 ∧ a ≤ d * Real.log 2 ∧
      3 * C / a + 4 * Czero + Ctwo < 4 / (a + c) :=
  ZeroFreeRegion.exists_sigmaOf_log_margin_constants_for_shift_bounds
    hC_pos hC_lt hCzero hCtwo hd

