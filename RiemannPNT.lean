    ∃ A : ℝ, 0 < A ∧
      (fun T => HardyTheorem.weightedIntegral n T) ~[atTop]
        (fun T => ((-1 : ℝ) ^ n * A) *
          T ^ ((2 * n : ℝ) + 1 / 4)) :=
  HardyTheorem.exists_positive_asymptotic_of_integral_asymptotic_target h

