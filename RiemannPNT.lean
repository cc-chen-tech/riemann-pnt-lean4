theorem log_deriv_zeta_finset_series_identity
    (σ : ℝ) (hσ : 1 < σ) (t : ℝ) (S : Finset ℕ) (a : ℕ → ℝ) :
      (∑ k ∈ S, a k *
        (-deriv riemannZeta ((σ : ℂ) + (k : ℂ) * Complex.I * t) /
          riemannZeta ((σ : ℂ) + (k : ℂ) * Complex.I * t)).re)
