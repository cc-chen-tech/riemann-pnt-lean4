      ∑' n : ℕ,
        Λ n *
          (∑ k ∈ S, a k * Real.cos ((k : ℝ) * (t * Real.log (n : ℝ)))) /
            (n : ℝ) ^ σ :=
  ZeroFreeRegion.log_deriv_zeta_finset_series_identity σ hσ t S a

