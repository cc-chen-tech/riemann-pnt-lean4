    ∃ r > 0, ∀ z : ℂ, z ≠ x → dist z x < r →
      ‖logDeriv f z - (n : ℂ) * (z - x)⁻¹‖ ≤ M :=
  ZeroFreeRegion.exists_punctured_ball_norm_logDeriv_sub_order_mul_inv_le_of_eventuallyEq
